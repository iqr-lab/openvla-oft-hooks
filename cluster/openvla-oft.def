Bootstrap: docker
From: nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04

%files
    cluster/openvla-oft-environment.yml /tmp/openvla-oft-environment.yml

%post
    set -eux

    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        ffmpeg \
        git \
        libegl1 \
        libglew2.2 \
        libglfw3 \
        libglib2.0-0 \
        libgl1 \
        libosmesa6 \
        libsm6 \
        libx11-6 \
        libxcursor1 \
        libxext6 \
        libxi6 \
        libxinerama1 \
        libxrandr2 \
        libxrender1 \
        patchelf \
        wget
    rm -rf /var/lib/apt/lists/*

    wget -qO /tmp/miniforge.sh https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh
    bash /tmp/miniforge.sh -b -p /opt/conda
    rm /tmp/miniforge.sh

    . /opt/conda/etc/profile.d/conda.sh
    conda env create -f /tmp/openvla-oft-environment.yml
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/openvla-oft/bin:/opt/conda/bin:$PATH
    export CONDA_DEFAULT_ENV=openvla-oft
    export PYTHONPATH=/workspace/openvla-oft-hooks:$PYTHONPATH
    export MUJOCO_GL=egl
    export PYOPENGL_PLATFORM=egl

%runscript
    exec "$@"
