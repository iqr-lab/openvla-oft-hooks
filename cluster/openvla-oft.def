Bootstrap: docker
From: nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04

%post
    set -eux

    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        ffmpeg \
        git \
        libegl1 \
        libglew2.2 \
        libglfw3 \
        libglib2.0-0 \
        libgl1 \
        libosmesa6 \
        libsm6 \
        libx11-6 \
        libxcursor1 \
        libxext6 \
        libxi6 \
        libxinerama1 \
        libxrandr2 \
        libxrender1 \
        patchelf \
        wget
    rm -rf /var/lib/apt/lists/*

    wget -qO /tmp/miniforge.sh https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh
    bash /tmp/miniforge.sh -b -p /opt/conda
    rm /tmp/miniforge.sh

    cat > /tmp/openvla-oft-environment.yml <<'EOF'
name: openvla-oft
channels:
  - conda-forge
dependencies:
  - python=3.10
  - pip
  - git
  - pip:
      - accelerate>=0.25.0
      - draccus==0.8.0
      - einops
      - huggingface_hub
      - imageio
      - imageio[ffmpeg]
      - json-numpy
      - jsonlines
      - matplotlib
      - numpy<2
      - peft==0.11.1
      - protobuf
      - pyyaml
      - rich
      - sentencepiece==0.1.99
      - timm==0.9.10
      - tokenizers==0.19.1
      - torch==2.2.0
      - torchvision==0.17.0
      - torchaudio==2.2.0
      - git+https://github.com/moojink/transformers-openvla-oft.git
      - wandb
      - tensorflow==2.15.0
      - tensorflow_datasets==4.9.3
      - tensorflow_graphics==2021.12.3
      - git+https://github.com/moojink/dlimp_openvla
      - diffusers==0.30.3
      - fastapi
      - uvicorn
      - robosuite==1.4.1
      - bddl
      - easydict
      - cloudpickle
      - gym
      - git+https://github.com/Lifelong-Robot-Learning/LIBERO.git
EOF

    . /opt/conda/etc/profile.d/conda.sh
    conda env create -f /tmp/openvla-oft-environment.yml
    conda clean -afy

    mkdir -p /.venv/bin
    ln -sf /opt/conda/envs/openvla-oft/bin/python /.venv/bin/python

%environment
    export PATH=/opt/conda/envs/openvla-oft/bin:/opt/conda/bin:$PATH
    export CONDA_DEFAULT_ENV=openvla-oft
    export PYTHONPATH=/workspace/openvla-oft-hooks:$PYTHONPATH
    export MUJOCO_GL=egl
    export PYOPENGL_PLATFORM=egl

%runscript
    exec "$@"
